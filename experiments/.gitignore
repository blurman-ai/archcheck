# Experiment artifacts: keep source, scripts and reports — ignore reproducible output.

# Python bytecode
__pycache__/
*.pyc

# line_duplication: rendered examples are regenerable via render_project_examples.py
line_duplication/examples/

# ai_repo_run: raw per-repo dup dumps and timing (reproducible via run_dup.sh)
ai_repo_run/*.txt
ai_repo_run/*.time
ai_repo_run/runs/
ai_repo_run/pilot_raw/

# ai_repo_run: corpus tables, per-commit hits, audit outputs, run archives —
# all regenerable via the discover/measure/check scripts in this dir. Older
# iteration dumps stay on disk for cross-checking, just out of git status.
# (corpus_50.tsv / _remove_plan.tsv / skipped_big.tsv are already tracked —
#  *.tsv does not un-track them.)
ai_repo_run/*.tsv
ai_repo_run/*.jsonl
ai_repo_run/*.json
ai_repo_run/*.stdout
ai_repo_run/per_commit_batches*/
ai_repo_run/runs_history/
ai_repo_run/verify_results/
ai_repo_run/.hardening_baseline
