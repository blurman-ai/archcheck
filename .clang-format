---
# Base — LLVM coding standards.
# One deliberate departure — Allman braces (see docs/code_style.md §"Why Allman").
# Any other difference from the LLVM default is a bug; fix it with a PR.
Language: Cpp
BasedOnStyle: LLVM
Standard: c++20

# Our deviation from the LLVM default (Attach).
BreakBeforeBraces: Allman

# Wider than the LLVM default of 80 — modern IDEs handle it easily.
ColumnLimit: 120

# Include-block grouping (standard → third-party → archcheck → the rest).
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^<[A-Za-z0-9_/.-]+\.h>'
    Priority: 1
  - Regex: '^<[A-Za-z0-9_/.-]+>'
    Priority: 2
  - Regex: '^"archcheck/'
    Priority: 3
  - Regex: '.*'
    Priority: 4
